generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("escort") // "admin" or "escort"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  escort    Escort?
}

model Escort {
  id          String   @id @default(cuid())
  name        String
  alias       String?
  age         Int
  city       String
  description String?
  services   String?  // JSON array as string: ["Acompañamiento", "Masaje"]
  phone      String?
  whatsapp  String?
  featured   Boolean  @default(false)
  active     Boolean  @default(true)
  mainPhoto  String?
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  photos    Photo[]
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  
  escortId  String
  escort    Escort   @relation(fields: [escortId], references: [id], onDelete: Cascade)
}